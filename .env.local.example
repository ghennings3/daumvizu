# Supabase — Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Supabase — secret key (nunca expor no client, apenas em Route Handlers)
SUPABASE_SECRET_KEY=

# Anthropic — usada apenas em Route Handlers do Next.js (geração de propostas)
ANTHROPIC_API_KEY=

# Google Gemini — provedor temporário de geração de propostas (ver src/lib/ai/gemini.ts)
GEMINI_API_KEY=
