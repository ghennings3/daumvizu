# Supabase — Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase — service role key (nunca expor no client, apenas em Route Handlers)
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic — usada apenas em Route Handlers do Next.js (geração de propostas)
ANTHROPIC_API_KEY=
